   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d1417991",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, random, warnings\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "import torch\n",
    "from torch import nn\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "\n",
    "from transformers import (\n",
    "    AutoTokenizer,\n",
    "    AutoModelForSequenceClassification,\n",
    "    get_cosine_schedule_with_warmup,\n",
    ")\n",
    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.metrics import f1_score, classification_report\n",
    "from sklearn.utils.class_weight import compute_class_weight\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# ── Reproducibility ──────────────────────────────────────────────────────────\n",
    "SEED = 42\n",
    "def seed_everything(seed):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "    torch.backends.cudnn.deterministic = True\n",
    "seed_everything(SEED)\n",
    "\n",
    "DEVICE = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Using device: {DEVICE}')\n",
    "if DEVICE.type == 'cuda':\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4e32f0cf",
   "metadata": {},
   "source": [
    "## 2. Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "58421954",
   "metadata": {},
   "outputs": [],
   "source": [
    "CFG = dict(\n",
    "    # ── Data paths (Kaggle input)\n",
    "    train_path  = '/kaggle/input/malto-recruitment-hackathon/train.csv',\n",
    "    test_path   = '/kaggle/input/malto-recruitment-hackathon/test.csv',\n",
    "    output_dir  = '/kaggle/working/',\n",
    "\n",
    "    # ── Model\n",
    "    # deberta-v3-small: best quality/speed trade-off on Kaggle T4\n",
    "    # Alternative if OOM: 'distilbert-base-uncased' (faster, slightly weaker)\n",
    "    model_name  = 'microsoft/deberta-v3-small',\n",
    "\n",
    "    num_labels  = 6,\n",
    "    max_len     = 512,       
    "\n",
    "    # ── Training\n",
    "    n_folds     = 5,         # StratifiedKFold cross-validation\n",
    "    epochs      = 4,\n",
    "    batch_size  = 8,         
    "    grad_accum  = 4,        
    "    lr          = 2e-5,\n",
    "    warmup_ratio= 0.1,\n",
    "    weight_decay= 0.01,\n",
    "    max_grad_norm = 1.0,\n",
    "\n",
    "    # ── Label map (for display only)\n",
    "    label_names = {0:'Human', 1:'DeepSeek', 2:'Grok', 3:'Claude', 4:'Gemini', 5:'ChatGPT'},\n",
    ")\n",
    "\n",
    "print('Config loaded ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "afa04ef7",
   "metadata": {},
   "source": [
    "## 3. Load & Explore Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5319f368",
   "metadata": {},
   "outputs": [],
   "source": [
    "train_df = pd.read_csv(CFG['train_path'])\n",
    "test_df  = pd.read_csv(CFG['test_path'])\n",
    "\n",
    "# Normalise column names (competition uses uppercase)\n",
    "train_df.columns = train_df.columns.str.upper()\n",
    "test_df.columns  = test_df.columns.str.upper()\n",
    "\n",
    "print(f'Train shape: {train_df.shape}')\n",
    "print(f'Test shape:  {test_df.shape}')\n",
    "print()\n",
    "print('Label distribution in train:')\n",
    "counts = train_df['LABEL'].value_counts().sort_index()\n",
    "for lbl, cnt in counts.items():\n",
    "    print(f\"  {lbl} ({CFG['label_names'][lbl]:>8}): {cnt:>4} samples  {'█'*int(cnt/20)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "aa9a83fc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Quick text-length analysis\n",
    "train_df['text_len'] = train_df['TEXT'].str.len()\n",
    "print('Text length stats (chars):')\n",
    "print(train_df.groupby('LABEL')['text_len'].describe()[['mean','50%','max']].round(0))\n",
    "\n",
    "# Drop helper column before training\n",
    "train_df.drop(columns=['text_len'], inplace=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9a01e392",
   "metadata": {},
   "source": [
    "## 4. Dataset & Tokeniser"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "91649efa",
   "metadata": {},
   "outputs": [],
   "source": [
    "tokenizer = AutoTokenizer.from_pretrained(CFG['model_name'])\n",
    "\n",
    "class TextDataset(Dataset):\n",
    "    def __init__(self, texts, labels=None, max_len=512):\n",
    "        self.texts   = texts.reset_index(drop=True)\n",
    "        self.labels  = labels.reset_index(drop=True) if labels is not None else None\n",
    "        self.max_len = max_len\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.texts)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        encoding = tokenizer(\n",
    "            str(self.texts[idx]),\n",
    "            max_length    = self.max_len,\n",
    "            padding       = 'max_length',\n",
    "            truncation    = True,\n",
    "            return_tensors= 'pt',\n",
    "        )\n",
    "        item = {\n",
    "            'input_ids'     : encoding['input_ids'].squeeze(0),\n",
    "            'attention_mask': encoding['attention_mask'].squeeze(0),\n",
    "        }\n",
    "        if 'token_type_ids' in encoding:\n",
    "            item['token_type_ids'] = encoding['token_type_ids'].squeeze(0)\n",
    "        if self.labels is not None:\n",
    "            item['labels'] = torch.tensor(int(self.labels[idx]), dtype=torch.long)\n",
    "        return item\n",
    "\n",
    "print('Tokeniser & Dataset class ready ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f40309bc",
   "metadata": {},
   "source": [
    "## 5. Training Utilities"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3fa1ab30",
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_class_weights(labels):\n",
    "    \"\"\"Compute inverse-frequency class weights to handle imbalance.\"\"\"\n",
    "    classes = np.arange(CFG['num_labels'])\n",
    "    weights = compute_class_weight('balanced', classes=classes, y=labels)\n",
    "    return torch.tensor(weights, dtype=torch.float).to(DEVICE)\n",
    "\n",
    "\n",
    "def train_one_epoch(model, loader, optimizer, scheduler, class_weights):\n",
    "    model.train()\n",
    "    loss_fn  = nn.CrossEntropyLoss(weight=class_weights)\n",
    "    total_loss = 0\n",
    "    optimizer.zero_grad()\n",
    "\n",
    "    for step, batch in enumerate(loader):\n",
    "        input_ids      = batch['input_ids'].to(DEVICE)\n",
    "        attention_mask = batch['attention_mask'].to(DEVICE)\n",
    "        labels         = batch['labels'].to(DEVICE)\n",
    "        kwargs = dict(input_ids=input_ids, attention_mask=attention_mask)\n",
    "        if 'token_type_ids' in batch:\n",
    "            kwargs['token_type_ids'] = batch['token_type_ids'].to(DEVICE)\n",
    "\n",
    "        outputs = model(**kwargs)\n",
    "        loss    = loss_fn(outputs.logits, labels) / CFG['grad_accum']\n",
    "        loss.backward()\n",
    "        total_loss += loss.item() * CFG['grad_accum']\n",
    "\n",
    "        if (step + 1) % CFG['grad_accum'] == 0:\n",
    "            nn.utils.clip_grad_norm_(model.parameters(), CFG['max_grad_norm'])\n",
    "            optimizer.step()\n",
    "            scheduler.step()\n",
    "            optimizer.zero_grad()\n",
    "\n",
    "    return total_loss / len(loader)\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def evaluate(model, loader):\n",
    "    model.eval()\n",
    "    all_preds, all_labels = [], []\n",
    "\n",
    "    for batch in loader:\n",
    "        input_ids      = batch['input_ids'].to(DEVICE)\n",
    "        attention_mask = batch['attention_mask'].to(DEVICE)\n",
    "        kwargs = dict(input_ids=input_ids, attention_mask=attention_mask)\n",
    "        if 'token_type_ids' in batch:\n",
    "            kwargs['token_type_ids'] = batch['token_type_ids'].to(DEVICE)\n",
    "\n",
    "        outputs = model(**kwargs)\n",
    "        preds   = outputs.logits.argmax(dim=-1).cpu().numpy()\n",
    "        all_preds.extend(preds)\n",
    "        if 'labels' in batch:\n",
    "            all_labels.extend(batch['labels'].numpy())\n",
    "\n",
    "    if all_labels:\n",
    "        macro_f1 = f1_score(all_labels, all_preds, average='macro')\n",
    "        return macro_f1, np.array(all_preds), np.array(all_labels)\n",
    "    return None, np.array(all_preds), None\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def predict_probs(model, loader):\n",
    "    \"\"\"Return softmax probabilities for ensemble/OOF averaging.\"\"\"\n",
    "    model.eval()\n",
    "    all_probs = []\n",
    "    for batch in loader:\n",
    "        input_ids      = batch['input_ids'].to(DEVICE)\n",
    "        attention_mask = batch['attention_mask'].to(DEVICE)\n",
    "        kwargs = dict(input_ids=input_ids, attention_mask=attention_mask)\n",
    "        if 'token_type_ids' in batch:\n",
    "            kwargs['token_type_ids'] = batch['token_type_ids'].to(DEVICE)\n",
    "        outputs = model(**kwargs)\n",
    "        probs   = torch.softmax(outputs.logits, dim=-1).cpu().numpy()\n",
    "        all_probs.append(probs)\n",
    "    return np.vstack(all_probs)\n",
    "\n",
    "print('Training utilities ready ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d5786808",
   "metadata": {},
   "source": [
    "## 6. Cross-Validated Training (5-Fold)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7f1d89c6",
   "metadata": {},
   "outputs": [],
   "source": [
    "skf = StratifiedKFold(n_splits=CFG['n_folds'], shuffle=True, random_state=SEED)\n",
    "\n",
    "oof_preds   = np.zeros(len(train_df), dtype=int)\n",
    "test_probs  = np.zeros((len(test_df), CFG['num_labels']), dtype=float)  # averaged over folds\n",
    "fold_scores = []\n",
    "\n",
    "test_dataset = TextDataset(test_df['TEXT'], max_len=CFG['max_len'])\n",
    "test_loader  = DataLoader(test_dataset, batch_size=CFG['batch_size']*2, shuffle=False, num_workers=2)\n",
    "\n",
    "for fold, (train_idx, val_idx) in enumerate(skf.split(train_df, train_df['LABEL'])):\n",
    "    print(f'\\n{\"=\"*60}')\n",
    "    print(f'  FOLD {fold+1} / {CFG[\"n_folds\"]}')\n",
    "    print(f'{\"=\"*60}')\n",
    "\n",
    "    tr = train_df.iloc[train_idx]\n",
    "    vl = train_df.iloc[val_idx]\n",
    "\n",
    "    train_ds = TextDataset(tr['TEXT'], tr['LABEL'], CFG['max_len'])\n",
    "    val_ds   = TextDataset(vl['TEXT'], vl['LABEL'], CFG['max_len'])\n",
    "\n",
    "    train_loader = DataLoader(train_ds, batch_size=CFG['batch_size'], shuffle=True,  num_workers=2, pin_memory=True)\n",
    "    val_loader   = DataLoader(val_ds,   batch_size=CFG['batch_size']*2, shuffle=False, num_workers=2)\n",
    "\n",
    "    # ── Model ────────────────────────────────────────────────────────────────\n",
    "    model = AutoModelForSequenceClassification.from_pretrained(\n",
    "        CFG['model_name'],\n",
    "        num_labels          = CFG['num_labels'],\n",
    "        ignore_mismatched_sizes = True,\n",
    "    ).to(DEVICE)\n",
    "\n",
    "    # Class weights from training fold only (no data leakage)\n",
    "    class_weights = compute_class_weights(tr['LABEL'].values)\n",
    "\n",
    "    # ── Optimizer with layer-wise LR decay ───────────────────────────────────\n",
    "    no_decay = ['bias', 'LayerNorm.weight']\n",
    "    optimizer_grouped_parameters = [\n",
    "        {'params': [p for n,p in model.named_parameters() if not any(nd in n for nd in no_decay)], 'weight_decay': CFG['weight_decay']},\n",
    "        {'params': [p for n,p in model.named_parameters() if     any(nd in n for nd in no_decay)], 'weight_decay': 0.0},\n",
    "    ]\n",
    "    optimizer = torch.optim.AdamW(optimizer_grouped_parameters, lr=CFG['lr'])\n",
    "\n",
    "    total_steps  = (len(train_loader) // CFG['grad_accum']) * CFG['epochs']\n",
    "    warmup_steps = int(total_steps * CFG['warmup_ratio'])\n",
    "    scheduler    = get_cosine_schedule_with_warmup(optimizer, warmup_steps, total_steps)\n",
    "\n",
    "    best_f1, best_epoch = 0.0, 0\n",
    "    best_model_path = f'{CFG[\"output_dir\"]}/fold{fold+1}_best.pt'\n",
    "\n",
    "    # ── Epoch loop ───────────────────────────────────────────────────────────\n",
    "    for epoch in range(CFG['epochs']):\n",
    "        train_loss = train_one_epoch(model, train_loader, optimizer, scheduler, class_weights)\n",
    "        val_f1, val_preds, val_labels = evaluate(model, val_loader)\n",
    "\n",
    "        print(f'  Epoch {epoch+1}/{CFG[\"epochs\"]}  |  loss: {train_loss:.4f}  |  val macro-F1: {val_f1:.4f}')\n",
    "\n",
    "        if val_f1 > best_f1:\n",
    "            best_f1    = val_f1\n",
    "            best_epoch = epoch + 1\n",
    "            torch.save(model.state_dict(), best_model_path)\n",
    "\n",
    "    print(f'  ✓ Best val macro-F1 = {best_f1:.4f}  (epoch {best_epoch})')\n",
    "    fold_scores.append(best_f1)\n",
    "\n",
    "    # ── Reload best checkpoint ───────────────────────────────────────────────\n",
    "    model.load_state_dict(torch.load(best_model_path, map_location=DEVICE))\n",
    "\n",
    "    # ── OOF predictions ──────────────────────────────────────────────────────\n",
    "    _, oof_fold_preds, _ = evaluate(model, val_loader)\n",
    "    oof_preds[val_idx] = oof_fold_preds\n",
    "\n",
    "    # ── Test predictions (accumulated) ───────────────────────────────────────\n",
    "    test_probs += predict_probs(model, test_loader)\n",
    "\n",
    "    # Free GPU memory between folds\n",
    "    del model\n",
    "    torch.cuda.empty_cache()\n",
    "\n",
    "print(f'\\n{\"=\"*60}')\n",
    "print(f'CV RESULTS')\n",
    "print(f'{\"=\"*60}')\n",
    "for i, s in enumerate(fold_scores):\n",
    "    print(f'  Fold {i+1}: {s:.4f}')\n",
    "print(f'  Mean : {np.mean(fold_scores):.4f} ± {np.std(fold_scores):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5da5c592",
   "metadata": {},
   "source": [
    "## 7. OOF Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d7ce0e2d",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.metrics import confusion_matrix\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "true_labels = train_df['LABEL'].values\n",
    "oof_f1 = f1_score(true_labels, oof_preds, average='macro')\n",
    "print(f'Overall OOF Macro F1: {oof_f1:.4f}\\n')\n",
    "print('Per-class report:')\n",
    "print(classification_report(\n",
    "    true_labels, oof_preds,\n",
    "    target_names=[CFG['label_names'][i] for i in range(6)]\n",
    "))\n",
    "\n",
    "# Confusion matrix\n",
    "cm = confusion_matrix(true_labels, oof_preds)\n",
    "fig, ax = plt.subplots(figsize=(8,6))\n",
    "sns.heatmap(\n",
    "    cm, annot=True, fmt='d', cmap='Blues',\n",
    "    xticklabels=[CFG['label_names'][i] for i in range(6)],\n",
    "    yticklabels=[CFG['label_names'][i] for i in range(6)],\n",
    ")\n",
    "ax.set_xlabel('Predicted'); ax.set_ylabel('True')\n",
    "ax.set_title(f'OOF Confusion Matrix  (Macro F1 = {oof_f1:.4f})')\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{CFG[\"output_dir\"]}/confusion_matrix.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b03181b3",
   "metadata": {},
   "source": [
    "## 8. Generate Submission"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "69663548",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Average test probabilities over all folds, then take argmax\n",
    "test_probs_avg   = test_probs / CFG['n_folds']\n",
    "final_test_preds = test_probs_avg.argmax(axis=1)\n",
    "\n",
    "print('Test prediction distribution:')\n",
    "unique, counts = np.unique(final_test_preds, return_counts=True)\n",
    "for u, c in zip(unique, counts):\n",
    "    print(f'  Label {u} ({CFG[\"label_names\"][u]:>8}): {c}')\n",
    "\n",
    "# Build submission\n",
    "# The test set must have an ID column; if not, use the row index\n",
    "if 'ID' in test_df.columns:\n",
    "    submission = pd.DataFrame({'ID': test_df['ID'], 'LABEL': final_test_preds})\n",
    "else:\n",
    "    submission = pd.DataFrame({'ID': test_df.index, 'LABEL': final_test_preds})\n",
    "\n",
    "sub_path = f'{CFG[\"output_dir\"]}/submission.csv'\n",
    "submission.to_csv(sub_path, index=False)\n",
    "print(f'\\nSubmission saved to {sub_path}')\n",
    "print(submission.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "51909df3",
